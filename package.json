{
  "name": "astra-monorepo",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*",
    "tools/*",
    "docs/*",
    "scripts/*",
    "config/*",
    "data/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@evilmartians/lefthook": "^2.1.6",
    "turbo": "^2.1.0",
    "typescript": "^5.6.0"
  },
  "packageManager": "bun@1.1.27",
  "trustedDependencies": ["@biomejs/biome", "@evilmartians/lefthook"]
}
